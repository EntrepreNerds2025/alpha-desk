# TradingView webhook auth (required for /api/webhooks/tradingview)
TRADINGVIEW_WEBHOOK_SECRET=replace-with-strong-secret

# Optional public base URL used by settings links/docs
VITE_PUBLIC_API_BASE_URL=https://api.ai-trading-office.app

# Supabase client config (for frontend auth/realtime)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-supabase-anon-key

# Optional monitoring
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
